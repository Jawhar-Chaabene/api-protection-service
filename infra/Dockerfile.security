FROM golang:1.26-alpine AS builder
WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/security-service ./cmd/security-service

FROM alpine:3.22
RUN adduser -D -g '' appuser
USER appuser
WORKDIR /app
COPY --from=builder /out/security-service /app/security-service
EXPOSE 50051
ENTRYPOINT ["/app/security-service"]
